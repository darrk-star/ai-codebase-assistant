{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Streamlit UI",
      "type": "python",
      "request": "launch",
      "module": "streamlit",
      "args": [
        "run",
        "app/ui.py"
      ],
      "console": "integratedTerminal",
      "justMyCode": true,
      "cwd": "${workspaceFolder}",
      "envFile": "${workspaceFolder}/.env",
      "python": "${workspaceFolder}\\.venv\\Scripts\\python.exe",
      "preLaunchTask": "Ensure Ollama Running"
    }
  ]
}
